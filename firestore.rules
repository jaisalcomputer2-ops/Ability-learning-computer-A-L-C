rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isTeacher() {
      return request.auth != null && 
        ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher') ||
         (request.auth.token.email != null && request.auth.token.email.lower() in ["jaisalcomputer2@gmail.com", "dqjaisal@gmail.com"]));
    }

    match /lessons/{docId} {
      allow read: if true;
      allow write: if isTeacher();
    }

    match /quizzes/{quizId} {
      allow read: if true;
      allow write: if isTeacher();
    }

    match /progress/{progressId} {
      allow read: if request.auth != null && (request.auth.uid == resource.data.userId);
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    match /users/{userId} {
      allow read: if true;
      allow write: if isTeacher();
      allow create, update: if request.auth != null && request.auth.uid == userId;
    }

    match /categories/{catId} {
      allow read: if true;
      allow write: if isTeacher();
    }

    match /config/{docId} {
      allow read: if true;
      allow write: if isTeacher();
    }

    match /exam_codes/{codeId} {
      allow read: if true;
      allow write: if isTeacher();
    }

    match /exam_results/{resultId} {
      allow read: if isTeacher();
      allow create: if true;
    }

    match /registration_requests/{requestId} {
      allow read, write: if true;
    }

    match /spelling_categories/{catId} {
      allow read: if true;
      allow write: if isTeacher();
    }
  }
}
